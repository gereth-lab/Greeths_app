def rate_limit(func):
    @wraps(func)
    def wrapper(*args, **kwargs):
        ip = request.remote_addr
        now = datetime.now()
        with lock:
            if ip in login_attempts:
                attempts, last_time = login_attempts[ip]
                if attempts >= 5 and (now - last_time).seconds < 300:
                    return "Too many attempts. Wait 5 minutes.", 429
                if attempts >= 20 and (now - last_time).seconds < 3600:
                    return "Blocked for 1 hour due to abuse.", 403
        return func(*args, **kwargs)
    return wrapper

def get_db():
    conn = sqlite3.connect(DATABASE, check_same_thread=False)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA foreign_keys = ON")
    conn.execute("PRAGMA journal_mode=WAL")
    return conn

