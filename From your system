            content = sanitize(data.get('content',''))
        else:
            content = sanitize(request.form.get('content',''))
        
        if content:
            conn.execute("INSERT INTO messages (from_user, to_user, content) VALUES (?,?,?)", (uid, friend_id, content))
            conn.commit()
        conn.close()
        return jsonify({"ok": True})

    content = f"""
    <div class="card">
        <div style="display:flex;align-items:center;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--border)">
            <img src="/uploads/{html.escape(friend['profile_pic'])}" class="avatar" alt="Avatar">
            <div style="margin-left:12px">
                <h3 style="margin:0">{html.escape(friend['full_name'])}</h3>
                <small style="color:#8a8d91">Active now</small>
            </div>
        </div>
        <div class="msg-box" id="msgBox"></div>
        <div id="typingIndicator" class="typing" style="display:none">
            <img src="/uploads/{html.escape(friend['profile_pic'])}" class="msg-avatar" alt="Avatar">
            <span>{html.escape(friend['full_name'])} is typing</span>
            <div class="typing-dots"><span></span><span></span><span></span></div>
        </div>
        <div class="chat-input-area">
            <input type="text" id="msgInput" placeholder="Type a message...">
            <button onclick="sendMsg()" class="btn btn-emoji">📤</button>
        </div>
    </div>
    <script>
        let typingTimer;
        async function loadMsgs() {{
            const data = await fetch('/api/messages/{friend_id}').then(r=>r.json());
            const box = document.getElementById('msgBox');
            const typingDiv = document.getElementById('typingIndicator');

            let html = '';
            for(let idx=0; idx<data.messages.length; idx++) {{
                const m = data.messages[idx];
                const isMe = m.from_user == {uid};
                const cls = isMe? 'me' : 'other';
                let avatar = isMe? '' : `<img src="/uploads/${{m.profile_pic}}" class="msg-avatar" alt="Avatar">`;
                let seen = '';
                if(isMe && m.is_read == 1 && idx == data.messages.length-1) {{
                    seen = '<div class="seen">Seen ✓</div>';
                }}

                const res = await fetch('/api/msg_reacts/' + m.id);
                const reacts = await res.json();
                let reactHtml = `<div class="reaction-row" style="margin-top:4px">
                    <button class="btn btn-emoji" onclick="reactMessage(${{m.id}},'heart')">${{reacts.my_heart?'❤️':'🤍'}} ${{reacts.heart}}</button>
                    <button class="btn btn-emoji" onclick="reactMessage(${{m.id}},'star')">${{reacts.my_star?'⭐':'☆'}} ${{reacts.star}}</button>
                </div>`;

                html += `<div class="msg ${{cls}}">${{avatar}}<div class="bubble">${{m.content}}${{reactHtml}}</div>${{seen}}</div>`;
            }}
            box.innerHTML = html;
            typingDiv.style.display = data.typing? 'flex' : 'none';
            box.scrollTop = box.scrollHeight;
        }}

        async function sendTyping() {{
            await post('/chat/{friend_id}', {{typing: true}});
        }}

        async function sendMsg() {{
            const input = document.getElementById('msgInput');
            if(!input.value.trim()) return;
            await post('/chat/{friend_id}', {{content: input.value}});
            input.value = '';
            loadMsgs();
        }}

        document.getElementById('msgInput').addEventListener('keypress', e => {{
            if(e.key==='Enter') sendMsg();
        }});

        document.getElementById('msgInput').addEventListener('input', () => {{
            clearTimeout(typingTimer);
            sendTyping();
            typingTimer = setTimeout(() => {{}}, 3000);
        }});

        loadMsgs();
        setInterval(loadMsgs, 1000);
    </script>
    """
    conn.close()
    return render_page(content, logged_in=True)

