@login_required
def chat(friend_id):
    uid = session['user_id']
    conn = get_db()
    friend = conn.execute("SELECT * FROM users WHERE id=?", (friend_id,)).fetchone()
    user_data = conn.execute("SELECT username FROM users WHERE id=?", (uid,)).fetchone()
