        name = sanitize(request.form.get('name',''))
        email = request.form.get('email','').lower().strip()
        pw = request.form.get('password','')
        username = sanitize(request.form.get('username',''))
        gender = request.form.get('gender', 'M')
        age = request.form.get('age', '18')
        if not verify_csrf():
            abort(403)
        if len(name) < 2 or not validate_password(pw) or len(username) < 3:
            return "Name min 2, password 8+ chars with 1 uppercase + 1 number + 1 special char, username min 3 chars", 400
        if not validate_email(email):
            return "Invalid email", 400
