def render_page(content, logged_in=False):
    uid = session.get('user_id')
    theme = '#00c853'
    if uid:
        conn = get_db()
        user = conn.execute("SELECT theme_color FROM users WHERE id=?", (uid,)).fetchone()
        if user: theme = user['theme_color']
        conn.close()
    return render_template_string(BASE_TEMPLATE, content=content, csrf_token=session.get('csrf_token',''), logged_in=logged_in, theme_color=theme)

@app.route('/uploads/<path:filename>')
def uploaded_file(filename):
    safe_filename = secure_filename(filename)
    if safe_filename != filename:
        abort(404)
    return send_from_directory(app.config['UPLOAD_FOLDER'], safe_filename)

@app.route('/', methods=['GET','POST'])
@rate_limit
def login():
    if request.method == 'POST':
        email = request.form.get('email','').lower().strip()
        pw = request.form.get('password','')
        if not verify_csrf():
            abort(403)
        conn = get_db()
        user = conn.execute("SELECT * FROM users WHERE email=?", (email,)).fetchone()
        conn.close()
        if user and check_password_hash(user['password_hash'], pw):
            session.clear()
            session['user_id'] = user['id']
            session['name'] = user['full_name']
            session['pic'] = user['profile_pic']
            generate_csrf()
            with lock:
                login_attempts.pop(request.remote_addr, None)
            return redirect('/feed')
        
        ip = request.remote_addr
        with lock:
            attempts, _ = login_attempts.get(ip, (0, datetime.now()))
            login_attempts[ip] = (attempts + 1, datetime.now())
        error = "<p style='color:#ff3b30;margin-top:8px'>Invalid credentials</p>"
    else:
        error = ""
        generate_csrf()

    content = f"""
    <div class="card" style="max-width:420px;margin:60px auto;text-align:center">
        <h2 style="margin-bottom:24px;background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-size:28px">Welcome to Greeths</h2>
        <form method="POST">
            <input type="hidden" name="csrf_token" value="{session['csrf_token']}">
            <input type="email" name="email" placeholder="Email" required style="margin-bottom:12px">
            <input type="password" name="password" placeholder="Password" required style="margin-bottom:12px">
            {error}
            <button class="btn" style="width:100%;margin-top:8px">Log In</button>
        </form>
        <p style="text-align:center;margin-top:20px;color:#8a8d91">No account? <a href="/register" style="color:var(--primary);font-weight:600">Sign up</a></p>
    </div>
    """
    return render_page(content, logged_in=False)

